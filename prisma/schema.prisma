generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SALES_EXECUTIVE
  DISPATCH_MANAGER
}

enum EnquiryStatus {
  OPEN
  QUOTED
  NEGOTIATION
  WON
  LOST
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum DispatchStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
}

model User {
  id                String       @id @default(cuid())
  name              String?
  email             String       @unique
  passwordHash      String?
  image             String?
  role              UserRole     @default(SALES_EXECUTIVE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  accounts          Account[]
  sessions          Session[]
  assignedEnquiries Enquiry[]    @relation("AssignedEnquiries")
  activityLogs      ActivityLog[]
}

model Customer {
  id        String     @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  state     String?
  archived  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  enquiries Enquiry[]
}

model Enquiry {
  id           String         @id @default(cuid())
  customerId   String
  customer     Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product      String
  grade        String?
  qty          Float
  unit         String
  deliveryDate DateTime?
  location     String?
  source       String?
  assignedToId String?
  assignedTo   User?          @relation("AssignedEnquiries", fields: [assignedToId], references: [id], onDelete: SetNull)
  priority     Priority       @default(MEDIUM)
  status       EnquiryStatus  @default(OPEN)
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  quotations   Quotation[]
  dispatches   Dispatch[]
  activityLogs ActivityLog[]
}

model Quotation {
  id             String              @id @default(cuid())
  enquiryId      String
  enquiry        Enquiry             @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  lineItems      Json
  subtotal       Float
  gst            Float
  total          Float
  terms          String?
  validityDate   DateTime?
  status         QuotationStatus     @default(DRAFT)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  quotationLines QuotationLineItem[]
}

model QuotationLineItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product     String
  grade       String?
  qty         Float
  unit        String
  rate        Float
  gstPct      Float
  amount      Float
}

model Dispatch {
  id                   String          @id @default(cuid())
  enquiryId            String
  enquiry              Enquiry         @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  vehicleNo            String?
  driverName           String?
  driverPhone          String?
  dispatchDate         DateTime?
  expectedDeliveryDate DateTime?
  status               DispatchStatus  @default(PENDING)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  enquiryId String
  enquiry   Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  message   String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}